# CRE CLI private key for signing on-chain transactions
# 64-character hex, NO 0x prefix
CRE_ETH_PRIVATE_KEY=your_sepolia_private_key_here

# Chainlink Data Streams API credentials
# Protected via Confidential HTTP — secrets stay in secure enclave
# For hackathon: use mock server (http://localhost:8787), these can be dummy values
DATA_STREAMS_API_KEY=mock-api-key
DATA_STREAMS_HMAC_SECRET=mock-hmac-secret
DATA_STREAMS_TIMESTAMP=auto
